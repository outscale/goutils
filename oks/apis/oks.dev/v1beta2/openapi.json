{
  "$schema": "https://spec.openapis.org/oas/3.0/schema/2024-10-18",
  "openapi": "3.0.0",
  "title": "nodepool",
  "version": "v1beta2",
  "components": {
    "schemas": {
      "NodePoolStatus": {
        "type": "object",
        "properties": {
          "last_error": {
            "type": "object",
            "properties": {
              "message": {
                "type": "string"
              },
              "posted": {
                "type": "string"
              }
            },
            "required": [ "message", "posted" ]
          },
          "progress":{
            "type": "object",
            "properties": {
              "attached": {
                "type": "integer"
              },
              "pending": {
                "type": "integer"
              },
              "ready": {
                "type": "integer"
              },
              "running": {
                "type": "integer"
              },
              "shutting_down": {
                "type": "integer"
              },
              "stopped": {
                "type": "integer"
              },
              "stopping": {
                "type": "integer"
              }
            },
            "required": [ "attached", "pending", "ready", "running", "shutting_down", "stopped", "stopping" ]
          },
          "state":{
            "type": "object",
            "properties": {
              "expires": {
                "type": "string"
              },
              "name": {
                "type": "string"
              }
            },
            "required": [ "expires", "name" ]
          }
        },
        "required": [ "last_error", "progress", "state" ]
      },
      "NodePoolSpec": {
        "properties": {
          "autoHealing": {
            "default": true,
            "type": "boolean"
          },
          "autoscaling": {
            "default": false,
            "type": "boolean"
          },
          "desiredNodes": {
            "default": 0,
            "maximum": 5000,
            "minimum": 0,
            "type": "integer"
          },
          "fgpu": {
            "$ref": "#/components/schemas/FGPU"
          },
          "flavour": {
            "enum": [
              "oks.debian12",
              "oks.debian12_nvidia",
              "oks.ubuntu22"
            ],
            "type": "string"
          },
          "helms": {
            "items": {
              "enum": [
                "gpu-operator",
                "prometheus",
                "ingress-nginx",
                "ollama"
              ],
              "type": "string"
            },
            "type": "array"
          },
          "ipPoolName": {
            "maxLength": 253,
            "type": "string"
          },
          "maxNodes": {
            "default": 0,
            "maximum": 5000,
            "minimum": 0,
            "type": "integer"
          },
          "minNodes": {
            "default": 0,
            "maximum": 5000,
            "minimum": 0,
            "type": "integer"
          },
          "nodeAnnotations": {
            "additionalProperties": {
              "maxLength": 261827,
              "type": "string"
            },
            "type": "object",
            "x-kubernetes-validations": [
              {
                "message": "Annotation name is invalid. It should follow the following schema: '[prefix.domain.name/]annotation_name' and match the following regular expression: '^([a-z0-9]([^/]{0,251}[a-z0-9])?/)?[a-z0-9]([-_.a-z0-9]{0,61}[a-z0-9])?$'",
                "rule": "self.all(k, k.matches('^([a-z0-9]([^/]{0,251}[a-z0-9])?/)?[a-z0-9]([-_.a-z0-9]{0,61}[a-z0-9])?$'))"
              }
            ]
          },
          "nodeLabels": {
            "additionalProperties": {
              "maxLength": 63,
              "pattern": "^([a-zA-Z0-9][a-zA-Z0-9._-]*[a-zA-Z0-9])?$",
              "type": "string"
            },
            "type": "object",
            "x-kubernetes-validations": [
              {
                "message": "Label name is invalid. It should follow the following schema: '[prefix.domain.name/]label_name' and match the following regular expression: '^([a-z0-9]([^/]{0,251}[a-z0-9])?/)?[a-z0-9]([-_.a-z0-9]{0,61}[a-z0-9])?$'",
                "rule": "self.all(k, k.matches('^([a-z0-9]([^/]{0,251}[a-z0-9])?/)?[a-z0-9]([-_.a-z0-9]{0,61}[a-z0-9])?$'))"
              }
            ]
          },
          "nodeType": {
            "pattern": "^(tinav[34567]\\.c([1-9]|[1-6][0-9]|7[0-8])r([1-9]|[1-9][0-9]|[1-9][0-9]{2}|10[0-3][0-9])(p[123])?|(c4\\.2xlarge|c4\\.4xlarge|c4\\.8xlarge|c4\\.large|c4\\.xlarge|c5\\.18xlarge|c5\\.2xlarge|c5\\.4xlarge|c5\\.8xlarge|c5\\.9xlarge|c5\\.large|c5\\.xlarge|io5\\.12xlarge|io5\\.18xlarge|io5\\.2xlarge|io5\\.4xlarge|io5\\.6xlarge|io5\\.8xlarge|m4\\.10xlarge|m4\\.2xlarge|m4\\.4xlarge|m4\\.large|m4\\.xlarge|m5\\.12xlarge|m5\\.2xlarge|m5\\.4xlarge|m5\\.large|m5\\.xlarge|mv3\\.2xlarge|mv3\\.large|mv3\\.xlarge|oc5\\.12xlarge|oc5\\.18xlarge|oc5\\.2xlarge|oc5\\.4xlarge|oc5\\.6xlarge|oc5\\.8xlarge|og4\\.2xlarge|og4\\.4xlarge|og4\\.8xlarge|og4\\.xlarge|om5\\.12xlarge|om5\\.18xlarge|om5\\.2xlarge|om5\\.4xlarge|om5\\.6xlarge|om5\\.8xlarge|p100\\.2xlarge|p100\\.4xlarge|p100\\.8xlarge|p3\\.2xlarge|p6\\.8xlarge|r4\\.16xlarge|r4\\.2xlarge|r4\\.4xlarge|r4\\.8xlarge|r4\\.large|r4\\.xlarge|440fxlegacy1\\.large|t2\\.micro|t2\\.small|t2\\.medium|t2\\.large|m3\\.medium|m3\\.large|m3\\.xlarge|m3\\.2xlarge|r3\\.large|r3\\.xlarge|r3\\.2xlarge|r3\\.4xlarge|r3\\.8xlarge)?|(inference7-(h200.4xlargeA|h100.large|l40.medium|l40.large|h100.2xlarge|h100.medium|h100.xlarge|h200.2xmedium|h200.2xsmall|h200.4xlarge)))$",
            "type": "string"
          },
          "physicalPlacement": {
            "$ref": "#/components/schemas/PhysicalPlacement"
          },
          "taint": {
            "default": false,
            "type": "boolean"
          },
          "upgradeStrategy": {
            "$ref": "#/components/schemas/UpgradeStrategy"
          },
          "volumes": {
            "items": {
              "$ref": "#/components/schemas/Volume"
            },
            "type": "array"
          },
          "zones": {
            "items": {
              "type": "string"
            },
            "minItems": 1,
            "type": "array"
          }
        },
        "required": [
          "nodeType"
        ],
        "type": "object",
        "x-kubernetes-validations": [
          {
            "message": "minNodes must be less or equal than desiredNodes",
            "rule": "!(has(self.minNodes)) || self.minNodes <= self.desiredNodes"
          },
          {
            "message": "maxNodes must be bigger or equal than desiredNodes",
            "rule": "!(has(self.maxNodes)) || self.maxNodes == 0 || self.maxNodes >= self.desiredNodes"
          },
          {
            "message": "Cannot set autoscaling to 'true' if maxNodes is 0 or the number of zones is bigger than 1 or if non-root custom volumes have been specified",
            "rule": "!self.autoscaling || (self.maxNodes != 0 && (!has(self.zones) || self.zones.size() <= 1) && (!has(self.volumes) || self.volumes.size() == 0 || (self.volumes.size() == 1 && self.volumes[0].device == 'root' && (!has(self.volumes[0].dir) || self.volumes[0].dir == '/'))))"
          },
          {
            "message": "Setting fGPU model is not supported with 'inference7-*' node types.",
            "rule": "!has(self.fgpu) || !has(self.fgpu.model) || !self.nodeType.startsWith('inference7-')"
          }
        ]
      },
      "FGPU":{
        "properties": {
          "k8s-operator": {
            "default": true,
            "type": "boolean"
          },
          "model": {
            "enum": [
              "nvidia-a100",
              "nvidia-a100-80",
              "nvidia-l40",
              "nvidia-p6",
              "nvidia-p100",
              "nvidia-v100",
              "nvidia-m60",
              "nvidia-h100"
            ],
            "type": "string"
          }
        },
        "type": "object"
      },
      "PhysicalPlacement": {
        "nullable": true,
        "properties": {
          "nodeAttractCluster": {
            "type": "string"
          },
          "nodeAttractServer": {
            "type": "string"
          },
          "nodeRepulseCluster": {
            "type": "string"
          },
          "nodeRepulseServer": {
            "type": "string"
          }
        },
        "type": "object"
      },
      "Volume": {
        "properties": {
          "device": {
            "pattern": "^(root|(s|xv)d([b-z][a-z]?))$",
            "type": "string"
          },
          "dir": {
            "type": "string"
          },
          "iops": {
            "default": 0,
            "maximum": 13000,
            "minimum": 0,
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "size": {
            "maximum": 14900,
            "minimum": 1,
            "type": "integer"
          },
          "snapshot": {
            "type": "string"
          },
          "type": {
            "enum": [
              "gp2",
              "io1",
              "standard"
            ],
            "type": "string"
          }
        },
        "required": [
          "dir",
          "type",
          "size"
        ],
        "type": "object",
        "x-kubernetes-validations": [
          {
            "message": "Only io1 storage type support iops. gp2 or standard need to have 0 iops.",
            "rule": "self.type == 'io1' ? self.iops >= 0 : self.iops == 0"
          },
          {
            "message": "The maximum number of IOPS allowed for io1 volumes is 13000 with a maximum performance ratio of 300 IOPS per gibibyte.",
            "rule": "self.iops <= self.size*300"
          },
          {
            "message": "'dir' must be '/' when 'device' is 'root'",
            "rule": "!(has(self.device) && self.device == 'root') || self.dir == '/'"
          },
          {
            "message": "'dir' can only be '/' when 'device' exists and equals 'root'",
            "rule": "!(self.dir == '/') || (has(self.device) && self.device == 'root')"
          },
          {
            "message": "When 'type' is 'io1', 'size' must be greater than or equal to 4",
            "rule": "!(self.type == 'io1' && self.size < 4)"
          },
          {
            "message": "'device' must not be 'sda1', use 'root' instead.",
            "rule": "!(has(self.device) && self.device == 'sda1')"
          },
          {
            "message": "Snapshots are not supported for root devices",
            "rule": "!(has(self.device) && self.device == 'root' && has(self.snapshot))"
          }
        ]
      },
      "UpgradeStrategy": {
        "properties": {
          "autoUpgradeEnabled": {
            "type": "boolean"
          },
          "autoUpgradeMaintenance": {
            "$ref": "#/components/schemas/AutoUpgradeMaintenance"
          },
          "maxSurge": {
            "type": "integer"
          },
          "maxUnavailable": {
            "type": "integer"
          }
        },
        "type": "object"
      },
      "AutoUpgradeMaintenance": {
          "properties": {
          "durationHours": {
            "maximum": 24,
            "minimum": 1,
            "type": "integer"
          },
          "rrule": {
            "pattern": "^FREQ=(DAILY|WEEKLY|MONTHLY|YEARLY)((;INTERVAL=[1-9][0-9]*)|(;COUNT=[1-9][0-9]*)|(;UNTIL=[0-9]{8}(T[0-9]{6}Z?)?)|(;BYSECOND=([0-9]|[1-5][0-9])(,([0-9]|[1-5][0-9]))*)|(;BYMINUTE=([0-9]|[1-5][0-9])(,([0-9]|[1-5][0-9]))*)|(;BYHOUR=([0-9]|1[0-9]|2[0-3])(,([0-9]|1[0-9]|2[0-3]))*)|(;BYDAY=([-+]?[1-5]?(MO|TU|WE|TH|FR|SA|SU))(,([-+]?[1-5]?(MO|TU|WE|TH|FR|SA|SU)))*)|(;BYMONTHDAY=([-+]?([1-9]|[12][0-9]|3[01]))(,([-+]?([1-9]|[12][0-9]|3[01])))*)|(;BYYEARDAY=([-+]?([1-9]|[1-9][0-9]|[1-2][0-9][0-9]|3[0-5][0-9]|36[0-6]))(,([-+]?([1-9]|[1-9][0-9]|[1-2][0-9][0-9]|3[0-5][0-9]|36[0-6])))*)|(;BYWEEKNO=([-+]?([1-9]|[1-4][0-9]|5[0-3]))(,([-+]?([1-9]|[1-4][0-9]|5[0-3])))*)|(;BYMONTH=([1-9]|1[0-2])(,([1-9]|1[0-2]))*)|(;BYSETPOS=([-+]?([1-9]|[1-9][0-9]|[1-2][0-9][0-9]|3[0-5][0-9]|36[0-6]))(,([-+]?([1-9]|[1-9][0-9]|[1-2][0-9][0-9]|3[0-5][0-9]|36[0-6])))*)|(;WKST=(MO|TU|WE|TH|FR|SA|SU)))*$",
            "type": "string"
          },
          "startHour": {
            "maximum": 23,
            "minimum": 0,
            "type": "integer"
          },
          "weekDay": {
            "enum": [
              "Mon",
              "Tue",
              "Wed",
              "Thu",
              "Fri",
              "Sat",
              "Sun"
            ],
            "type": "string"
          }
        },
        "type": "object"
      }
    }
  }
}
